# STM32CubeIDE / Eclipse metadata (keep shareable core project files)
.settings/
.metadata/
RemoteSystemsTempFiles/

# Build output directories
Debug/
Release/
**/Debug/
**/Release/

# Common embedded build artifacts
*.o
*.obj
*.d
*.su
*.elf
*.bin
*.hex
*.map
*.list
*.srec
*.a
*.lib
*.i
*.ii
*.asm

# Autogenerated build fragments inside build output folders
Debug/**/makefile
Release/**/makefile
Debug/**/sources.mk
Release/**/sources.mk
Debug/**/objects.mk
Release/**/objects.mk
Debug/**/objects.list
Release/**/objects.list
Debug/**/subdir.mk
Release/**/subdir.mk

# Logs and temporary files
*.log
*.tmp
*.bak
*.swp
*.swo
*~

# Tool / debug caches
*.launch
*.cache
*.proxy_cache

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Python cache (in case helper scripts are added)
__pycache__/
*.pyc